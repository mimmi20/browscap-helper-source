{
  "name": "mimmi20/browscap-helper-source",
  "description": "the source interface for the browscap helper",
  "license": "MIT",
  "authors": [
    {
      "name": "Thomas Müller",
      "homepage": "https://github.com/mimmi20",
      "role": "Developer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/mimmi20/browscap-helper-source/graphs/contributors"
    }
  ],
  "require": {
    "php": "~8.5.0 || ~8.6.0",
    "ext-mbstring": "*",
    "mimmi20/ua-browser-type": "^12.0.1",
    "mimmi20/ua-device-type": "^12.0.2",
    "ramsey/uuid": "^4.9.2",
    "symfony/console": "^8.0.7",
    "symfony/finder": "^8.0.6",
    "symfony/yaml": "^8.0.6"
  },
  "require-dev": {
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xmlwriter": "*",
    "donatj/phpuseragentparser": "^1.11.0",
    "ergebnis/composer-normalize": "^2.50.0",
    "jaybizzle/crawler-detect": "^1.3.7",
    "jbelien/phpstan-sarif-formatter": "^1.2.0",
    "laminas/laminas-diactoros": "^3.8.0",
    "matomo/device-detector": "dev-master",
    "mimmi20/browser-detector": "^10.0.34",
    "mimmi20/coding-standard": "^7.0.27",
    "mobiledetect/mobiledetectlib": "^4.8.10",
    "nikic/php-parser": "^5.7.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.42",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "rector/rector": "^2.3.9",
    "rector/type-perfect": "^2.1.2",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "symfony/http-foundation": "^8.0.7",
    "symfony/process": "^8.0.5",
    "symplify/phpstan-rules": "^14.9.11",
    "tomasvotruba/cognitive-complexity": "^1.0.0",
    "tomasvotruba/type-coverage": "^2.1.0",
    "tomasvotruba/unused-public": "^2.2.0",
    "whichbrowser/parser": "^2.1.8",
    "woothee/woothee-testset": "^1.13.0"
  },
  "suggest": {
    "ext-http": "to parse headers in the WhichBrowserSource",
    "ext-json": "required for several sources",
    "ext-pdo": "required for the PdoSource",
    "ext-simplexml": "required for the EndorphinSource or the SinergiSource",
    "browscap/browscap": "To read these useragents",
    "donatj/phpuseragentparser": "To read these useragents",
    "jaybizzle/crawler-detect": "To read these useragents",
    "matomo/device-detector": "To read these useragents",
    "mobiledetect/mobiledetectlib": "To read these useragents",
    "mongodb/mongodb": "To read these useragents",
    "whichbrowser/parser": "To read these useragents",
    "woothee/woothee-testset": "To read these useragents"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "BrowscapHelper\\Source\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": true
    },
    "lock": false,
    "preferred-install": {
      "browscap/browscap": "source",
      "cbschuld/browser.php": "source",
      "donatj/phpuseragentparser": "source",
      "endorphin-studio/browser-detector-tests": "source",
      "jaybizzle/crawler-detect": "source",
      "mimmi20/browser-detector": "source",
      "mobiledetect/mobiledetectlib": "source",
      "piwik/device-detector": "source",
      "sinergi/browser-detector": "source",
      "whichbrowser/parser": "source",
      "woothee/woothee-testset": "source",
      "yzalis/ua-parser": "source",
      "zsxsoft/php-useragent": "source",
      "*": "dist"
    },
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  }
}
